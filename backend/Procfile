# Railway / Render process definitions
# Phase 1-2: gunicorn (WSGI).
# Phase 3: swap web process to:
#   web: uvicorn config.asgi:application --workers 3 --host 0.0.0.0 --port $PORT

web: gunicorn config.wsgi:application --workers 3 --timeout 60 --bind 0.0.0.0:$PORT
worker: celery -A config.celery worker --loglevel=info --concurrency=4
beat: celery -A config.celery beat --loglevel=info --scheduler django_celery_beat.schedulers:DatabaseScheduler
release: python manage.py migrate --noinput && python manage.py collectstatic --noinput
