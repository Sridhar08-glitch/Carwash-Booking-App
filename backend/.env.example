# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=ehefwuhihufwnjrfejnkjnkerfjnvjnnvfjjnkrejddejjnefm
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ── Database (Postgres) ───────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@host:5432/dbname
# CONN_MAX_AGE=0  # Keep 0 for per-request RLS context isolation; increase only with PgBouncer

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:password@host:6379/0

# ── Object Storage (Cloudflare R2 or AWS S3) ─────────────────────────────────
USE_S3=False                  # Set True to enable S3/R2 media storage
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket
AWS_S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com   # R2 only
AWS_S3_REGION_NAME=auto                                               # R2 only; use real region for S3

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Firebase Cloud Messaging (FCM push notifications) ────────────────────────
FCM_ENABLED=False
# Paste the full Firebase service-account JSON as a single-line string:
FCM_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...","client_email":"...","client_id":"..."}

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ── Feature flags ─────────────────────────────────────────────────────────────
GEO_ENABLED=False          # PostGIS service areas — Phase 4 only
CHANNELS_ENABLED=False     # Django Channels real-time — Phase 3 only
MAPS_API_KEY=              # Google Maps Directions API key (ETA in live tracking)
SMS_ENABLED=False          # Set True to actually deliver OTP via SMS provider
SOCIAL_AUTH_ENABLED=False  # Set True + configure allauth to enable Google/Apple login

# ── SMS provider (used when SMS_ENABLED=True) ─────────────────────────────────
SMS_PROVIDER=twilio        # Options: twilio | aws_sns
# Twilio:
SMS_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMS_AUTH_TOKEN=your-auth-token
SMS_FROM_NUMBER=+15005550006   # E.164 format

# ── App-level ─────────────────────────────────────────────────────────────────
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
FRONTEND_URL=https://yourdomain.com
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com
